# Application login (server-only)
APP_USERNAME=archive
APP_PASSWORD=replace-with-a-long-random-password
SESSION_SECRET=replace-with-at-least-32-random-characters
APP_ORIGIN=https://f.twincap.pro

# Use mock for local preview or webdav for the production Nextcloud adapter.
STORAGE_DRIVER=mock
MAX_UPLOAD_BYTES=26214400

# WebDAV adapter (server-only; never prefix these with NEXT_PUBLIC_)
NEXTCLOUD_URL=https://files.twincap.pro
NEXTCLOUD_USERNAME=replace-with-nextcloud-user
NEXTCLOUD_APP_PASSWORD=replace-with-nextcloud-app-password
NEXTCLOUD_WEBDAV_ROOT=/remote.php/dav/files/replace-with-nextcloud-user
